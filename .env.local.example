# ============================================================
# どれか1つを選ぶ (必須)
# ============================================================
LLM_PROVIDER=openai            # openai | azure | ollama
EMBED_DIM=1536                 # openai/azure: 1536, ollama nomic-embed-text: 768

# ============================================================
# LLM_PROVIDER=openai のとき
# ============================================================
# [必須]
# OPENAI_API_KEY=sk-...
# [任意]
# OPENAI_BASE_URL=https://your-endpoint/v1   # OpenAI互換エンドポイント (省略時はOpenAI公式)
# OPENAI_CHAT_MODEL=gpt-4o-mini              # 省略時: gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # 省略時: text-embedding-3-small

# ============================================================
# LLM_PROVIDER=azure のとき
# ============================================================
# [必須]
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key
# [任意]
# AZURE_OPENAI_API_VERSION=2024-10-21        # 省略時: 2024-10-21
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o        # 省略時: gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small  # 省略時: text-embedding-3-small

# ============================================================
# LLM_PROVIDER=ollama のとき (完全ローカル/無料)
# ============================================================
# [任意] (すべてデフォルトあり)
# OLLAMA_BASE_URL=http://localhost:11434/v1   # 省略時: http://localhost:11434/v1
# OLLAMA_CHAT_MODEL=llama3.1                  # 省略時: llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text     # 省略時: nomic-embed-text
# EMBED_DIM=768                               # ↑を使うときはこちらに変更
