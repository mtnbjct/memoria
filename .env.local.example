# --- どれか1つを選ぶ ---
LLM_PROVIDER=openai            # openai | azure | ollama
EMBED_DIM=1536                 # openai/azure text-embedding-3-small=1536, ollama nomic-embed-text=768

# --- LLM_PROVIDER=openai のとき ---
OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- LLM_PROVIDER=azure のとき (会社用) ---
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_API_VERSION=2024-10-21
# AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- LLM_PROVIDER=ollama のとき (完全ローカル/無料) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# EMBED_DIM=768  # ↑を使うときはこちら
